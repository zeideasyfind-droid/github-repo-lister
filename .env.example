# Formspree configuration (optional)
# Create a free account at https://formspree.io and add your Form ID here for proper email lead routing.
# If not provided, the application will fallback to direct submission via Google Forms.
VITE_FORMSPREE_ID=

# Property Formatter (server-only secrets, never exposed to the browser)
# Google Gemini API key used to format property listings. Needs the
# "Generative Language API" enabled on the associated Google Cloud project.
GEMINI_API_KEY=

# Google Places/Geocoding API key used to resolve society/locality names
# from a pasted Google Maps link.
GOOGLE_PLACES_API_KEY=
